# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
TELEGRAM_WEBHOOK_PORT=8443

# Brawl Stars API Configuration
BRAWL_STARS_API_TOKEN=your_brawl_stars_api_token_here
BRAWL_STARS_API_BASE_URL=https://api.brawlstars.com/v1

# CoreStats Configuration
CORE_STATS_API_BASE_URL=https://api.core-stats.com
CORE_STATS_API_KEY=your_core_stats_key_here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/brawl_stars_draft
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Application Configuration
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_PORT=8000
APP_HOST=0.0.0.0

# Recommendation Engine Configuration
RECOMMENDATION_WEIGHTS_CONFIG=config/recommendation_weights.json
PREDICTION_MODEL_PATH=models/prediction_model.pkl
CONFIDENCE_THRESHOLD=0.6

# Scheduling Configuration
SCHEDULE_UPDATE_INTERVAL_HOURS=6
SCHEDULE_PREDICTION_RETRAIN_INTERVAL_HOURS=24
SCHEDULE_META_SNAPSHOT_INTERVAL_HOURS=12

# Caching Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
CACHE_ENABLED=true

# Feature Flags
FEATURE_DRAFT_EXPORT=true
FEATURE_TEAM_HISTORY=true
FEATURE_STATISTICS=true
FEATURE_MATCHUP_VIEWER=true
