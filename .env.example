# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Brawl Stars API Configuration
BRAWL_STARS_API_KEY=your_api_key_here

# Database
DATABASE_PATH=data/brawl_stars.db

# Update Settings
AUTO_UPDATE_ENABLED=true
UPDATE_INTERVAL_HOURS=1

# Logging
LOG_LEVEL=INFO

# Data Sources
ENABLE_BRAWLSTARS_API=true
ENABLE_BRAWLAPI_FALLBACK=true
ENABLE_BRAWLIFY_META=true
